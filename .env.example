# ============================================
# GRANTED PATH — Environment Variables
# ============================================
# Copy this file to .env.local for local dev,
# or configure these vars in Vercel dashboard for production.

# ============================================
# App
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================
# Database — PostgreSQL (Neon / Supabase / self-hosted)
# ============================================
# Main pooled connection (use for app queries)
DATABASE_URL="postgresql://user:password@host/grantedpath?sslmode=require&pgbouncer=true"
# Direct unpooled connection (use for Prisma migrations)
DIRECT_URL="postgresql://user:password@host/grantedpath?sslmode=require"

# ============================================
# Redis — Upstash (rate limiting, session cache, AI cache)
# ============================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================
# NextAuth v5
# ============================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# Set to true in production so NextAuth trusts the host
AUTH_TRUST_HOST="true"

# ============================================
# OAuth providers (NextAuth)
# ============================================
# Google: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub: https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ============================================
# Anthropic API (Claude for AI tutoring)
# ============================================
# https://console.anthropic.com/
ANTHROPIC_API_KEY=""
# Optional: override default model
ANTHROPIC_DEFAULT_MODEL="claude-opus-4-6"

# ============================================
# Stripe (billing + subscriptions)
# ============================================
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook signing secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=""

# Price IDs (created in Stripe dashboard)
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_MASTER_MONTHLY=""
STRIPE_PRICE_MASTER_YEARLY=""

# ============================================
# Resend (transactional email)
# ============================================
# https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="Granted Path <noreply@grantedpath.com>"

# ============================================
# Analytics — PostHog
# ============================================
# https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# ============================================
# Error tracking — Sentry
# ============================================
# https://sentry.io/settings/
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# ============================================
# Storage — Vercel Blob (user uploads, content library)
# ============================================
BLOB_READ_WRITE_TOKEN=""

# ============================================
# Internal
# ============================================
# Cron secret for authenticated cron endpoints (Vercel Cron)
CRON_SECRET=""
# Admin bootstrap email (first-time super admin)
BOOTSTRAP_ADMIN_EMAIL=""
